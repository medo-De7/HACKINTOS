{
  "name": "HACKINTOS",
  "version": "1.0.0",
  "type": "module",
  "description": "Cyber Terminal web client & HTML viewer & network inspector",
  "main": "server/app.js",
  "bin": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "dev": "nodemon --watch server --watch client server/app.js",
    "dist": "node scripts/build.js"
  },
  "keywords": [
    "cyber",
    "terminal",
    "inspector",
    "browser",
    "hackintos"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.4.0",
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "pkg": "^5.8.1"
  ,
  "pkg": {
    "assets": [
      "client/**/*",
      "public/**/*",
      "README.md"
    ],
    "scripts": [
      "server/**/*.js"
    ]
  }
  }
}
