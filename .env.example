# Example environment variables for HACKINTOS
# Copy this file to `.env` and fill in values before running in development

# Server
PORT=3000
NODE_ENV=development

# Security / secrets
SESSION_SECRET=replace_this_with_a_secure_random_string

# Proxy / HTTP client
PROXY_TIMEOUT=15000
ALLOW_SELF_SIGNED=false

# Socket.IO
SOCKET_IO_PATH=/socket.io

# Logging
LOG_LEVEL=info

# Optional external APIs
# Example: API_KEY_GOOGLE="your-google-api-key"
API_KEY_EXAMPLE=

# Storage and uploads
STORAGE_DIR=storage

# Allowed hosts (comma-separated) — leave empty for all during dev
ALLOWED_HOSTS=

# Notes:
# - Do not commit your real `.env` file. Keep secrets out of version control.
# - For production, set `NODE_ENV=production` and use strong secret values.
